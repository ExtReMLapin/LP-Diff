{
    "name": "LP-Diff",
    "phase": "train",
    "gpu_ids": [0],
    "path": {
        "log": "logs",
        "tb_logger": "tb_logger",
        "results": "results",
        "checkpoint": "checkpoint",
        "resume_state": null
    },
    "datasets": {
        "train": {
            "name": "MDLP",
            "mode": "LRHR", 
            "dataroot": "/home/pierre/dataset_plaques/",
            "width": 224,
            "height": 112,
            "batch_size": 1200,
            "num_workers": 8,
            "use_shuffle": true
        },
        "val": {
            "name": "MDLP",
            "mode": "LRHR",
            "width": 224,
            "height": 112,
            "dataroot": "/home/pierre/dataset_plaques/",
            "val_batch_size": 300,
            "data_len": 100
        }
    },
    "model": {
        "finetune_norm": false,
        "unet": {
            "in_channel": 6,   
            "out_channel": 3,
            "inner_channel": 64,
            "channel_multiplier": [
                1,  
                2,  
                4,  
                8,      
                8    
            ],
            "attn_res": [28],
            "res_blocks": 2,
            "dropout": 0.1
        },
        "beta_schedule": {
            "train": {
                "schedule": "linear",
                "n_timestep": 1000,
                "linear_start": 1e-6,
                "linear_end": 1e-2
            },
            "val": {
                "schedule": "linear",
                "n_timestep": 1000,
                "linear_start": 1e-6,
                "linear_end": 1e-2
            }
        },
        "diffusion": {
            "image_size": 224,
            "channels": 3,
            "conditional": true
        }
    },
    "train": {
        "use_prerain_MTA": false, // use the pretrained MTA model
        "MTA": "experiments/LP-Diff_MTA_only/checkpoint/best_mta.pt",
        "freeze_MTA": true,        // <--- Ligne ajoutée pour geler le MTA
        "lambda_mta": 1.0,         // <--- Le loss L1 du MTA n'aura plus d'impact sur la diffusion
        "resume_training": false,
        "n_iter": 10000,          // (Optionnel) Baisse cette valeur pour que le LR s'ajuste bien
        "val_freq": 2e4,
        "val_warmup_epochs": 5,
        "val_check_epochs": 10,
        "save_checkpoint_freq": 1e4,    
        "print_freq": 200,  
        "optimizer": {
            "type": "adam",
            "lr": 1e-4
        },
        "ema_scheduler": { // not used now
            "step_start_ema": 5000,
            "update_ema_every": 1,
            "ema_decay": 0.9999
        }
    },
    "wandb": {
        "project": "LP-Diff"
    }
}
